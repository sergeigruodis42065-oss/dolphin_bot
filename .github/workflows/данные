// ─── API: Доступные слоты ────────────────────────────────────
app.get('/api/slots', async (req, res) => {
  const { activity_id, date } = req.query;
  if (!activity_id || !date) {
    return res.status(400).json({ error: 'activity_id и date обязательны' });
  }
  try {
    const { rows } = await db.query(
      `SELECT s.*, 
        (s.capacity - COALESCE(b.booked, 0)) AS available
       FROM slots s
       LEFT JOIN (
         SELECT slot_id, SUM(people_count) AS booked
         FROM bookings WHERE status != 'cancelled'
         GROUP BY slot_id
       ) b ON b.slot_id = s.id
       WHERE s.activity_id = $1 AND s.date = $2
       ORDER BY s.time`,
      [activity_id, date]
    );
    res.json(rows);
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

